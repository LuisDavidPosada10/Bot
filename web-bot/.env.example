# ───── Requeridas ─────
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# ───── Servidor ─────
PORT=3000
ALLOWED_ORIGIN=http://localhost:5173

# ───── MongoDB (opcional — sin URI = solo memoria L1) ─────
# Usa MONGODB_URI o MONGO_URI + MONGO_DB_NAME
MONGODB_URI=
MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/?appName=WebBot
MONGO_DB_NAME=webbot
SYNC_EVERY_N_MESSAGES=5
SYNC_DEBOUNCE_MS=30000
MONGO_SESSION_TTL_DAYS=30

# Ventana de historial al LLM (ahorro de tokens)
HISTORY_MAX_TURNS=10
HISTORY_MAX_TOKENS=7000
HISTORY_MAX_TURNS_PORTFOLIO=6
HISTORY_MAX_TOKENS_PORTFOLIO=4000

# ───── Tavily (fallback búsqueda web) ─────
TAVILY_API_KEY=

# ───── Formspree (mismo endpoint que portafolio-web) ─────
FORMSPREE_ENDPOINT=https://formspree.io/f/mjgpzbry
PORTFOLIO_URL=http://localhost:5173
CONTACT_TO=posadaluis451@gmail.com

# WhatsApp (modo portafolio) — E.164 sin +, ej. 573001234567
WHATSAPP_NUMBER=

# ───── CORS (portafolio + bot frontend) ─────
ALLOWED_ORIGIN=http://localhost:5173,http://localhost:5174
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@example.com
CONTACT_TO=
