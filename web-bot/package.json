{
  "name": "web-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Backend Web Bot con LangChain, memoria híbrida y endpoints HTTP",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:tools": "tsx scripts/test-all-tools.ts",
    "test:e2e": "tsx scripts/e2e-chat-battery.ts"
  },
  "dependencies": {
    "@langchain/community": "^1.0.4",
    "@langchain/core": "^1.0.5",
    "@langchain/openai": "^1.0.0",
    "@langchain/tavily": "^1.0.0",
    "axios": "^1.12.2",
    "cheerio": "^1.0.0",
    "dotenv": "^16.6.1",
    "duck-duck-scrape": "^2.2.7",
    "express": "^4.19.2",
    "langchain": "^1.0.6",
    "mongoose": "^9.7.3",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.10",
    "pdf-parse": "^1.1.1",
    "pino": "^10.0.0",
    "pino-http": "^11.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.18.12",
    "@types/nodemailer": "^6.4.14",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "nodemon": "^3.1.4",
    "pino-pretty": "^10.3.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.10.5",
    "typescript": "^5.5.4",
    "vitest": "^4.1.9"
  }
}
